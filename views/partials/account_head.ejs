<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> · <%= siteName %></title>
  <link rel="icon" href="/icons/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/dash.css">
</head>
<body>
<%- include('sprite') %>
<div class="dash-shell">

  <aside class="dash-sidebar">
    <div class="dash-brand">
      <div class="mark"><svg class="icon"><use href="#icon-logo"></use></svg></div>
      <div>
        <div class="name"><%= siteName %></div>
        <div class="subname">Dashboard</div>
      </div>
    </div>

    <nav style="flex:1">
      <div class="dash-nav-group">
        <a href="/dashboard" class="dash-nav-item <%= path === '/dashboard' || path.startsWith('/dashboard/new') || path.startsWith('/dashboard/edit') ? 'active' : '' %>">
          <svg class="icon"><use href="#icon-dashboard"></use></svg><span class="label">Dashboard</span>
        </a>
      </div>

      <div class="dash-nav-group">
        <div class="dash-nav-label">Key system</div>
        <a href="/dashboard/key-scripts" class="dash-nav-item <%= path === '/dashboard/key-scripts' ? 'active' : '' %>">
          <svg class="icon"><use href="#icon-shield"></use></svg><span class="label">Key scripts</span>
        </a>
        <a href="/dashboard/keys" class="dash-nav-item <%= path === '/dashboard/keys' ? 'active' : '' %>">
          <svg class="icon"><use href="#icon-key"></use></svg><span class="label">Keys</span>
        </a>
      </div>

      <div class="dash-nav-group">
        <div class="dash-nav-label">Account</div>
        <a href="/dashboard/profile" class="dash-nav-item <%= path === '/dashboard/profile' ? 'active' : '' %>">
          <svg class="icon"><use href="#icon-user"></use></svg><span class="label">Profile</span>
        </a>
      </div>
    </nav>

    <div class="dash-sidebar-foot">
      <form action="/logout" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="dash-nav-item" style="width:100%;border:none;background:none;cursor:pointer;text-align:left">
          <svg class="icon"><use href="#icon-x"></use></svg><span class="label">Log out</span>
        </button>
      </form>
    </div>
  </aside>

  <div class="dash-main">
    <div class="dash-topbar">
      <div class="dash-breadcrumb">
        <span><%= siteName %></span> <svg class="icon" style="width:12px;height:12px"><use href="#icon-arrow-right"></use></svg> <strong><%= title %></strong>
      </div>
      <div class="dash-topbar-right">
        <a href="/" class="btn btn-outline btn-sm"><svg class="icon"><use href="#icon-external"></use></svg>View site</a>
        <span class="text-dim" style="font-size:13px;font-weight:600"><%= user.username %></span>
      </div>
    </div>

    <div class="dash-content">
