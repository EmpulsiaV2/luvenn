<%- include('partials/head') %>
<main>
  <div class="auth-wrap">
    <h1>Create your account</h1>
    <p class="sub">Publish scripts and manage everything from your dashboard.</p>

    <% if (error) { %>
      <div class="alert alert-error"><svg class="icon"><use href="#icon-x"></use></svg><%= error %></div>
    <% } %>

    <form action="/register" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" value="<%= values.username || '' %>" autocomplete="username" required>
        <div class="help-text">3-20 characters: letters, numbers, underscores.</div>
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" value="<%= values.email || '' %>" autocomplete="email" required>
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" autocomplete="new-password" required>
        <div class="help-text">At least 8 characters.</div>
      </div>
      <div class="form-group">
        <label for="confirm_password">Confirm password</label>
        <input type="password" id="confirm_password" name="confirm_password" autocomplete="new-password" required>
      </div>
      <button type="submit" class="btn btn-primary btn-block">Create account</button>
    </form>

    <div class="auth-foot">Already have an account? <a href="/login">Log in</a></div>
  </div>
</main>
<%- include('partials/footer') %>
