<%- include('partials/head') %>
<main>
  <div class="container" style="max-width:820px;padding-top:36px">

    <div class="script-header">
      <div>
        <div class="badge-row mb-24">
          <span class="badge badge-category"><%= script.category %></span>
          <% if (script.has_key_system) { %><span class="badge badge-key"><svg class="icon"><use href="#icon-key"></use></svg>Key system</span><% } %>
          <span class="badge badge-<%= script.status %>"><%= script.status %></span>
        </div>
        <h1><%= script.title %></h1>
        <p class="text-dim" style="margin-top:6px">
          by <strong style="color:var(--text)"><%= script.username %></strong>
          <% if (script.game_name) { %> · for <strong style="color:var(--text)"><%= script.game_name %></strong><% } %>
          · <%= timeAgo(script.created_at) %>
        </p>
      </div>
      <% if (canManage) { %>
        <div class="flex gap-8">
          <a href="/dashboard/edit/<%= script.id %>" class="btn btn-outline btn-sm"><svg class="icon"><use href="#icon-edit"></use></svg>Edit</a>
        </div>
      <% } %>
    </div>

    <% if (script.description) { %>
      <p class="mb-24"><%= script.description %></p>
    <% } %>

    <% if (script.has_key_system && script.key_link) { %>
      <div class="alert" style="background:rgba(255,193,7,0.08);border:1px solid rgba(255,193,7,0.25);color:#e0b13a">
        <svg class="icon"><use href="#icon-key"></use></svg>
        This script requires a key. <a href="<%= script.key_link %>" target="_blank" rel="noopener noreferrer" style="color:#ffc107;font-weight:600;margin-left:4px">Get key <svg class="icon"><use href="#icon-external"></use></svg></a>
      </div>
    <% } %>

    <div class="section-title" style="margin-top:8px">
      <h2 style="font-size:15px">Loadstring</h2>
    </div>
    <div class="loadstring-box mb-24">
      <span><%= loadstring %></span>
      <button class="btn btn-outline btn-sm" data-copy="<%= loadstring %>" style="flex-shrink:0">
        <svg class="icon"><use href="#icon-copy"></use></svg>Copy
      </button>
    </div>

    <div class="alert" style="background:var(--bg-elevated);border:1px solid var(--border);color:var(--text-dim)">
      <svg class="icon"><use href="#icon-shield"></use></svg>
      Source is never shown on the site — run it through the loadstring above in your executor.
    </div>

    <div class="meta mt-24 mb-24" style="border:none;padding-top:0">
      <span><svg class="icon"><use href="#icon-eye"></use></svg><%= script.views %> views</span>
      <span><svg class="icon"><use href="#icon-download"></use></svg><%= script.fetches %> executor fetches</span>
    </div>

  </div>
</main>
<%- include('partials/footer') %>
