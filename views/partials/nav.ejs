<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="brand"><svg class="icon"><use href="#icon-logo"></use></svg>luv<span class="dot">e</span>nn</a>
    <div class="nav-links">
      <a href="/docs" class="nav-link <%= path === '/docs' ? 'active' : '' %>">Docs</a>
      <a href="/dashboard" class="nav-link <%= path.startsWith('/dashboard') ? 'active' : '' %>">Dashboard</a>
      <a href="<%= discordInvite %>" target="_blank" rel="noopener noreferrer" class="nav-link">Discord</a>
      <a href="/faq" class="nav-link <%= path === '/faq' ? 'active' : '' %>">F.A.Q</a>
      <% if (user) { %>
        <form action="/logout" method="POST" style="display:inline">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn btn-ghost btn-sm">Log out</button>
        </form>
      <% } else { %>
        <a href="/login" class="nav-link">Sign in</a>
        <a href="/register" class="btn btn-primary btn-sm">Sign up</a>
      <% } %>
    </div>
  </div>
</nav>
