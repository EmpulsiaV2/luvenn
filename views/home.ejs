<%- include('partials/head') %>
<main>
  <section class="hero">
    <div class="container">
      <h1>Protect your code<br>with <span class="accent">luvenn</span></h1>
      <p>Publish Roblox scripts through a single loader link. Every script is run through multiple layers of obfuscation before it ever leaves our servers &mdash; no third-party APIs involved.</p>

      <div class="hero-actions">
        <% if (user) { %>
          <a href="/dashboard" class="btn btn-primary"><svg class="icon"><use href="#icon-dashboard"></use></svg>Go to dashboard</a>
        <% } else { %>
          <a href="/register" class="btn btn-primary"><svg class="icon"><use href="#icon-user"></use></svg>Get started</a>
        <% } %>
        <a href="/docs" class="btn btn-outline"><svg class="icon"><use href="#icon-external"></use></svg>Read the docs</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="feature-grid">
        <div class="feature-card">
          <div class="feature-icon"><svg class="icon"><use href="#icon-shield"></use></svg></div>
          <h3>Multi-layer obfuscation</h3>
          <p>Every publish runs your source through comment stripping, string encoding, and an XOR + base64 encrypted loader &mdash; generated fresh, with randomized internals, on every save.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon c-blue"><svg class="icon"><use href="#icon-key"></use></svg></div>
          <h3>Loader links</h3>
          <p>Every script gets a single <code>loadstring</code> URL. Source is never displayed anywhere on the site &mdash; not even to you, outside your own edit form.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon c-green"><svg class="icon"><use href="#icon-eye"></use></svg></div>
          <h3>Real execution stats</h3>
          <p>Track views, executor loads, and blocked browser requests per script, with a live chart of daily executions on your dashboard.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon c-rose"><svg class="icon"><use href="#icon-ban"></use></svg></div>
          <h3>Browser-blocked delivery</h3>
          <p>The loader endpoint only serves executors &mdash; regular browsers requesting your script's raw file are turned away and logged.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-banner">
        <div>
          <h2>Ready to protect your first script?</h2>
          <p>Create an account and publish in under a minute.</p>
        </div>
        <% if (user) { %>
          <a href="/dashboard/new" class="btn btn-primary"><svg class="icon"><use href="#icon-plus"></use></svg>Add a script</a>
        <% } else { %>
          <a href="/register" class="btn btn-primary"><svg class="icon"><use href="#icon-user"></use></svg>Create free account</a>
        <% } %>
      </div>
    </div>
  </section>
</main>
<%- include('partials/footer') %>
