<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> · <%= siteName %> admin</title>
  <link rel="icon" href="/icons/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/dash.css">
</head>
<body>
<%- include('sprite') %>
<div class="dash-shell">

  <aside class="dash-sidebar">
    <div class="dash-brand">
      <div class="mark"><svg class="icon"><use href="#icon-shield"></use></svg></div>
      <div>
        <div class="name"><%= siteName %> Admin</div>
        <div class="subname">Control Panel</div>
      </div>
    </div>

    <nav style="flex:1">
      <div class="dash-nav-group">
        <div class="dash-nav-label">Overview</div>
        <a href="/admin" class="dash-nav-item <%= active === 'overview' ? 'active' : '' %>">
          <svg class="icon"><use href="#icon-dashboard"></use></svg><span class="label">Overview</span>
        </a>
      </div>

      <div class="dash-nav-group">
        <div class="dash-nav-label">Scripts</div>
        <a href="/admin/scripts" class="dash-nav-item <%= active === 'scripts' ? 'active' : '' %>">
          <svg class="icon"><use href="#icon-script"></use></svg><span class="label">All scripts</span>
          <span class="count"><%= navCounts.scripts %></span>
        </a>
        <a href="/admin/scripts?filter=key" class="dash-nav-item">
          <svg class="icon"><use href="#icon-key"></use></svg><span class="label">Key scripts</span>
          <span class="count"><%= navCounts.key_scripts %></span>
        </a>
      </div>

      <div class="dash-nav-group">
        <div class="dash-nav-label">Community</div>
        <a href="/admin/users" class="dash-nav-item <%= active === 'users' ? 'active' : '' %>">
          <svg class="icon"><use href="#icon-user"></use></svg><span class="label">Users</span>
          <span class="count"><%= navCounts.users %></span>
        </a>
      </div>
    </nav>

    <div class="dash-sidebar-foot">
      <a href="/" class="btn btn-outline btn-sm btn-block"><svg class="icon"><use href="#icon-external"></use></svg>View site</a>
      <form action="/logout" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-danger btn-sm btn-block"><svg class="icon"><use href="#icon-x"></use></svg>Log out</button>
      </form>
    </div>
  </aside>

  <div class="dash-main">
    <div class="dash-topbar">
      <div class="dash-breadcrumb">
        <span>Dashboard</span> <svg class="icon" style="width:12px;height:12px"><use href="#icon-arrow-right"></use></svg> <strong><%= title %></strong>
      </div>
      <div class="dash-topbar-right">
        <span class="dash-clock" id="dash-clock"><svg class="icon"><use href="#icon-clock"></use></svg><span id="dash-clock-text">--:--:--</span></span>
      </div>
    </div>

    <div class="dash-content">
