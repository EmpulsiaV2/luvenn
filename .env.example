# --- Database (Neon) ---
# Get this from your Neon project dashboard -> Connection Details -> "Pooled connection"
DATABASE_URL=postgresql://user:password@ep-xxxxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# --- Sessions ---
# Generate a long random string, e.g: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_string

# --- App ---
NODE_ENV=production
PORT=3000
SITE_URL=https://luvenn.xyz
SITE_NAME=luvenn

# --- Registration ---
# Set to "true" to require an invite code to register (optional extra layer)
REQUIRE_INVITE_CODE=false
INVITE_CODE=

# --- Rate limiting ---
TRUST_PROXY=1
