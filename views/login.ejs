<%- include('partials/head') %>
<main>
  <div class="auth-wrap">
    <h1>Welcome back</h1>
    <p class="sub">Log in to manage and publish your scripts.</p>

    <% if (error) { %>
      <div class="alert alert-error"><svg class="icon"><use href="#icon-x"></use></svg><%= error %></div>
    <% } %>

    <form action="/login" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="next" value="<%= typeof next !== 'undefined' ? next : '' %>">
      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" autocomplete="username" required>
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" autocomplete="current-password" required>
      </div>
      <button type="submit" class="btn btn-primary btn-block">Log in</button>
    </form>

    <div class="auth-foot">Don't have an account? <a href="/register">Sign up</a></div>
  </div>
</main>
<%- include('partials/footer') %>
