<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="brand"><svg class="icon"><use href="#icon-logo"></use></svg>luv<span class="dot">e</span>nn</a>
    <div class="nav-links">
      <a href="/" class="nav-link <%= path === '/' ? 'active' : '' %>">
        <svg class="icon"><use href="#icon-globe"></use></svg><span class="label">Browse</span>
      </a>
      <% if (user) { %>
        <a href="/dashboard" class="nav-link <%= path.startsWith('/dashboard') ? 'active' : '' %>">
          <svg class="icon"><use href="#icon-dashboard"></use></svg><span class="label">Dashboard</span>
        </a>
        <% if (user.is_admin) { %>
          <a href="/admin" class="nav-link <%= path.startsWith('/admin') ? 'active' : '' %>">
            <svg class="icon"><use href="#icon-shield"></use></svg><span class="label">Admin</span>
          </a>
        <% } %>
        <a href="/dashboard/new" class="btn btn-primary btn-sm">
          <svg class="icon"><use href="#icon-plus"></use></svg>Publish
        </a>
        <form action="/logout" method="POST" style="display:inline">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn btn-ghost btn-sm">Log out</button>
        </form>
      <% } else { %>
        <a href="/login" class="nav-link">Log in</a>
        <a href="/register" class="btn btn-primary btn-sm">
          <svg class="icon"><use href="#icon-user"></use></svg>Sign up
        </a>
      <% } %>
    </div>
  </div>
</nav>
